#!/bin/bash
# ane — Interactive CLI for ANE-Training
# Usage: ./ane              (interactive menu)
#        ./ane train        (training demo)
#        ./ane bench        (benchmark)
#        ./ane generate     (text generation)
#        ./ane explore      (ANE class explorer)
#        ./ane info         (hardware info)
#        ./ane test         (run libane tests)
#        ./ane help         (show commands)

set -e

# ===== Paths =====
DIR="$(cd "$(dirname "$0")" && pwd)"
EXAMPLES="$DIR/examples"
LIBANE="$DIR/libane"

# ===== Colors =====
R='\033[0;31m'
G='\033[0;32m'
Y='\033[1;33m'
B='\033[0;34m'
C='\033[0;36m'
W='\033[1;37m'
D='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m'

# ===== Helpers =====
ok()   { echo -e "  ${G}+${NC} $1"; }
fail() { echo -e "  ${R}x${NC} $1"; }
info() { echo -e "  ${B}>${NC} $1"; }
dim()  { echo -e "  ${D}$1${NC}"; }

# ===== System Check =====
check_system() {
    if [ "$(uname -m)" != "arm64" ]; then
        fail "Apple Silicon erforderlich (du hast: $(uname -m))"
        exit 1
    fi
    if ! xcode-select -p &>/dev/null; then
        fail "Xcode Command Line Tools nicht gefunden"
        info "Installiere mit: xcode-select --install"
        exit 1
    fi
}

# ===== Build =====
ensure_built() {
    local target="$1"
    local binary="$2"
    if [ ! -f "$EXAMPLES/$binary" ]; then
        echo -e "  ${D}Baue $binary ...${NC}"
        (cd "$EXAMPLES" && make "$target" 2>/dev/null) || {
            fail "Build fehlgeschlagen. Versuche: cd examples && make $target"
            return 1
        }
    fi
}

ensure_all_built() {
    local needed=0
    [ ! -f "$EXAMPLES/demo_train" ] && needed=1
    [ ! -f "$EXAMPLES/bench" ] && needed=1
    [ ! -f "$EXAMPLES/generate" ] && needed=1
    [ ! -f "$EXAMPLES/explore" ] && needed=1

    if [ $needed -eq 1 ]; then
        echo ""
        info "Erstmaliger Start — baue alle Binaries ..."
        echo ""
        (cd "$EXAMPLES" && make all 2>&1 | while read -r line; do dim "  $line"; done) || {
            fail "Build fehlgeschlagen"
            exit 1
        }
        ok "Alle Binaries gebaut"
        echo ""
    fi
}

# ===== Hardware Info =====
cmd_info() {
    check_system
    ensure_built "demo_train" "demo_train"

    echo ""
    echo -e "  ${BOLD}Hardware-Erkennung${NC}"
    echo ""

    # Run a quick ANE init to get hardware info
    "$EXAMPLES/demo_train" 2>/dev/null | head -6 | while read -r line; do
        echo -e "  $line"
    done

    echo ""
    echo -e "  ${D}System:${NC}  $(sw_vers -productName) $(sw_vers -productVersion) ($(sw_vers -buildVersion))"
    echo -e "  ${D}Arch:${NC}    $(uname -m)"
    echo -e "  ${D}Xcode:${NC}   $(xcode-select -p)"
    echo ""
}

# ===== Commands =====
cmd_train() {
    check_system
    ensure_built "demo_train" "demo_train"
    echo ""
    "$EXAMPLES/demo_train"
    echo ""
}

cmd_bench() {
    check_system
    ensure_built "bench_bin" "bench"
    echo ""
    "$EXAMPLES/bench"
    echo ""
}

cmd_generate() {
    check_system
    ensure_built "generate_bin" "generate"
    echo ""
    "$EXAMPLES/generate"
    echo ""
}

cmd_explore() {
    check_system
    ensure_built "explore_bin" "explore"
    echo ""
    "$EXAMPLES/explore"
    echo ""
}

cmd_test() {
    check_system
    echo ""
    info "libane Tests ..."
    echo ""
    (cd "$LIBANE" && make test 2>&1)
    echo ""
}

cmd_about() {
    echo ""
    echo -e "  ${BOLD}Was ist ANE-Training?${NC}"
    echo ""
    echo -e "  Dein Mac hat einen ${W}Neural Engine (ANE)${NC} — einen KI-Chip mit 16 Cores"
    echo -e "  und bis zu 38 TOPS. Apple erlaubt offiziell nur Inference (CoreML)."
    echo -e "  Dieses Projekt knackt diese Beschränkung: ${G}Training direkt auf dem ANE.${NC}"
    echo ""
    echo -e "  ${BOLD}Warum ist das besser als normales Training?${NC}"
    echo ""
    echo -e "  ${W}CPU-Training${NC}          Langsam. Dein M-Chip hat 10-20 TOPS auf der CPU,"
    echo -e "                        aber der ANE liefert ${W}9-38 TFLOPS${NC} für Matrix-Ops."
    echo ""
    echo -e "  ${W}GPU-Training (MLX)${NC}    Gut für große Modelle, aber braucht viel Strom"
    echo -e "                        und teilt sich den Speicher mit allem anderen."
    echo -e "                        Der ANE arbeitet ${W}isoliert und stromsparend${NC}."
    echo ""
    echo -e "  ${W}ANE-Training${NC}          ${G}Direkt auf dem KI-Beschleuniger.${NC}"
    echo -e "                        9.4 TFLOPS auf M3 Pro, bis zu 38 TOPS auf M4."
    echo -e "                        Zero-Copy I/O, Background-QoS (42% schneller)."
    echo -e "                        ${W}1 Compile für unbegrenzt viele Training-Steps.${NC}"
    echo ""
    echo -e "  ${BOLD}Das Besondere (USP):${NC}"
    echo ""
    echo -e "  ${C}1.${NC} ${W}Dynamic Spatial Packing${NC} — Weights als IOSurface-Input statt BLOBFILE."
    echo -e "     Einmal kompilieren, Weights beliebig oft ändern. Kein Recompile-Limit."
    echo ""
    echo -e "  ${C}2.${NC} ${W}35 private API-Klassen${NC} entdeckt (andere Projekte kennen nur 4)."
    echo -e "     Version-Detection: überlebt Apple API-Änderungen automatisch."
    echo ""
    echo -e "  ${C}3.${NC} ${W}Stabile C-API (libane)${NC} — 73KB, von jeder Sprache nutzbar."
    echo -e "     Dein Code gegen ane.h bricht nie, egal was Apple ändert."
    echo ""
    echo -e "  ${C}4.${NC} ${W}100% lokal, 100% privat.${NC} Kein Cloud-Service, kein Account,"
    echo -e "     keine Daten die dein Gerät verlassen."
    echo ""
    echo -e "  ${D}Mehr: ./ane help (Befehle) | README.md (Doku) | ROADMAP.md (Nächste Schritte)${NC}"
    echo ""
}

cmd_help() {
    echo ""
    echo -e "  ${BOLD}Befehle:${NC}"
    echo ""
    echo -e "    ${C}./ane${NC}              Interaktives Menü"
    echo -e "    ${C}./ane about${NC}        Was ist das? Warum ANE-Training?"
    echo -e "    ${C}./ane train${NC}        Training Demo (Y=2X, Dynamic Spatial Packing)"
    echo -e "    ${C}./ane bench${NC}        Auto-Benchmark (TFLOPS + Chip-Vergleich)"
    echo -e "    ${C}./ane generate${NC}     Shakespeare Text-Generation auf ANE"
    echo -e "    ${C}./ane explore${NC}      ANE Framework Explorer (35 Klassen)"
    echo -e "    ${C}./ane info${NC}         Hardware-Erkennung"
    echo -e "    ${C}./ane test${NC}         libane Test-Suite"
    echo -e "    ${C}./ane help${NC}         Diese Hilfe"
    echo ""
}

# ===== Banner =====
show_banner() {
    echo ""
    echo -e "  ${BOLD}${W} ___    _   __ ______${NC}"
    echo -e "  ${BOLD}${W}/   |  / | / // ____/${NC}"
    echo -e "  ${BOLD}${W}/ /| | /  |/ // __/${NC}     ${D}Apple Neural Engine${NC}"
    echo -e "  ${BOLD}${W}/ ___ |/ /|  // /___${NC}    ${D}Training Platform${NC}"
    echo -e "  ${BOLD}${W}/_/  |_/_/ |_//_____/${NC}   ${D}1 Compile · ∞ Steps${NC}"
    echo ""
}

# ===== Interactive Menu =====
cmd_menu() {
    check_system

    show_banner
    ensure_all_built

    # Quick hardware detect
    local hw_line
    hw_line=$("$EXAMPLES/demo_train" 2>/dev/null | grep "Hardware:" | head -1)
    if [ -n "$hw_line" ]; then
        echo -e "  ${G}+${NC} $hw_line"
    fi

    local build_line
    build_line=$("$EXAMPLES/demo_train" 2>/dev/null | grep "Build:" | head -1)
    if [ -n "$build_line" ]; then
        echo -e "  ${G}+${NC} $build_line"
    fi

    local api_line
    api_line=$("$EXAMPLES/demo_train" 2>/dev/null | grep "API:" | head -1)
    if [ -n "$api_line" ]; then
        echo -e "  ${G}+${NC} $api_line"
    fi

    while true; do
        echo ""
        echo -e "  ${D}─────────────────────────────────────${NC}"
        echo ""
        echo -e "    ${W}1${NC}  Training Demo       ${D}Train Y=2X, 1 Compile, 60 Steps${NC}"
        echo -e "    ${W}2${NC}  Benchmark            ${D}Messe deine ANE TFLOPS${NC}"
        echo -e "    ${W}3${NC}  Text Generation      ${D}Shakespeare auf dem ANE${NC}"
        echo -e "    ${W}4${NC}  ANE Explorer          ${D}35 private Klassen erkunden${NC}"
        echo -e "    ${W}5${NC}  Hardware Info         ${D}Chip, Cores, API-Status${NC}"
        echo -e "    ${W}6${NC}  libane Tests          ${D}Test-Suite laufen lassen${NC}"
        echo ""
        echo -e "    ${W}?${NC}  Was ist das?           ${D}Warum ANE-Training? USP.${NC}"
        echo -e "    ${W}d${NC}  Dokumentation         ${D}README im Browser öffnen${NC}"
        echo -e "    ${W}q${NC}  Beenden"
        echo ""
        echo -ne "  ${BOLD}Auswahl: ${NC}"

        read -r choice

        case "$choice" in
            1) cmd_train ;;
            2) cmd_bench ;;
            3) cmd_generate ;;
            4) cmd_explore ;;
            5) cmd_info ;;
            6) cmd_test ;;
            '?'|about) cmd_about ;;
            d|D)
                if [ -f "$DIR/README.md" ]; then
                    if command -v open &>/dev/null; then
                        open "https://github.com/slavko-at-klincov-it/ANE-Training"
                    else
                        info "README: $DIR/README.md"
                    fi
                fi
                ;;
            q|Q|"") echo ""; break ;;
            *) fail "Unbekannte Auswahl: $choice" ;;
        esac
    done
}

# ===== Main =====
case "${1:-}" in
    about|what|"?") cmd_about ;;
    train)    cmd_train ;;
    bench)    cmd_bench ;;
    generate) cmd_generate ;;
    explore)  cmd_explore ;;
    info)     cmd_info ;;
    test)     cmd_test ;;
    help|-h|--help) cmd_help ;;
    "")       cmd_menu ;;
    *)
        fail "Unbekannter Befehl: $1"
        cmd_help
        exit 1
        ;;
esac
