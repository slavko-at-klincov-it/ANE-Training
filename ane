#!/bin/bash
# ane — Interactive CLI for ANE-Training
# Usage: ./ane              (interactive menu)
#        ./ane train        (training demo)
#        ./ane bench        (benchmark)
#        ./ane generate     (text generation)
#        ./ane explore      (ANE class explorer)
#        ./ane info         (hardware info)
#        ./ane test         (run libane tests)
#        ./ane help         (show commands)
#        ./ane --lang=de    (force German)
#        ./ane --lang=en    (force English)
#        ANE_LANG=de ./ane  (German via env)

set -e

# ===== Language Detection =====
# Priority: --lang=xx flag > ANE_LANG env > system locale > English default
_LANG_FLAG=""
for arg in "$@"; do
    case "$arg" in
        --lang=de) _LANG_FLAG=de ;;
        --lang=en) _LANG_FLAG=en ;;
    esac
done

if [ -n "$_LANG_FLAG" ]; then
    # Explicit --lang flag: highest priority
    L="$_LANG_FLAG"
elif [ -n "${ANE_LANG:-}" ]; then
    # ANE_LANG env var: second priority
    L="$ANE_LANG"
else
    # System locale detection: default English, German if locale is de
    LANG_CODE="${LANG:-en}"
    if [[ "$LANG_CODE" == de* ]] || [[ "${LC_ALL:-}" == de* ]]; then
        L=de
    else
        L=en
    fi
fi

# Bilingual string helper: t "English" "German"
t() {
    if [ "$L" = "de" ]; then echo "$2"; else echo "$1"; fi
}

# ===== Paths =====
DIR="$(cd "$(dirname "$0")" && pwd)"
EXAMPLES="$DIR/examples"
LIBANE="$DIR/libane"
PROFILE="$DIR/.ane_profile"
DEVICE_PROFILE="$HOME/.ane/device_profile.md"

# ===== Device Profile =====
# Creates ~/.ane/device_profile.md on first run with full system info.
# Updated when ./ane bench runs or hardware changes detected.

create_device_profile() {
    mkdir -p "$(dirname "$DEVICE_PROFILE")"

    # System info
    local _os_name _os_ver _os_build _arch _hostname
    _os_name=$(sw_vers -productName 2>/dev/null || echo "macOS")
    _os_ver=$(sw_vers -productVersion 2>/dev/null || echo "?")
    _os_build=$(sw_vers -buildVersion 2>/dev/null || echo "?")
    _arch=$(uname -m)
    _hostname=$(scutil --get ComputerName 2>/dev/null || hostname -s 2>/dev/null || echo "?")

    # CPU info
    local _cpu_brand _cpu_cores _pcores _ecores _ram_bytes _ram_gb
    _cpu_brand=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "?")
    _cpu_cores=$(sysctl -n hw.ncpu 2>/dev/null || echo "?")
    _pcores=$(sysctl -n hw.perflevel0.logicalcpu 2>/dev/null || echo "?")
    _ecores=$(sysctl -n hw.perflevel1.logicalcpu 2>/dev/null || echo "?")
    _ram_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo "0")
    _ram_gb=$(( _ram_bytes / 1073741824 ))

    # ANE info (from quick bench if available)
    local _ane_arch="" _ane_chip="" _ane_cores="" _ane_api="" _ane_tflops="" _ane_tops="" _ane_thermal=""
    if [ -f "$EXAMPLES/bench" ]; then
        local _quick
        _quick=$("$EXAMPLES/bench" --quick 2>/dev/null)
        if [ -n "$_quick" ]; then
            _ane_tflops=$(echo "$_quick" | sed -n 's/.*TFLOPS:\([^|]*\).*/\1/p')
            _ane_tops=$(echo "$_quick" | sed -n 's/.*TOPS:\([^|]*\).*/\1/p')
            _ane_chip=$(echo "$_quick" | sed -n 's/.*CHIP:\([^|]*\).*/\1/p')
            _ane_arch=$(echo "$_quick" | sed -n 's/.*ARCH:\([^|]*\).*/\1/p')
            _ane_cores=$(echo "$_quick" | sed -n 's/.*CORES:\([^|]*\).*/\1/p')
            _ane_api=$(echo "$_quick" | sed -n 's/.*API:\([^|]*\).*/\1/p')
            _ane_thermal=$(echo "$_quick" | sed -n 's/.*THERMAL:\(.*\)/\1/p')
        fi
    fi

    # Load full benchmark data if available
    local _peak="" _sustained="" _dispatch="" _best_kernel="" _efficiency="" _optimal_qos=""
    if [ -f "$PROFILE" ]; then
        . "$PROFILE" 2>/dev/null
        _peak="$peak_tflops"
        _sustained="$sustained_tflops"
        _dispatch="$dispatch_overhead_ms"
        _best_kernel="$best_kernel"
        _efficiency="$efficiency_pct"
        _optimal_qos="$optimal_qos"
    fi

    # Xcode
    local _xcode_path
    _xcode_path=$(xcode-select -p 2>/dev/null || echo "not installed")

    # Write profile
    cat > "$DEVICE_PROFILE" <<PROFILE_EOF
# ANE Device Profile
> Auto-generated by \`./ane\` — do not edit manually.
> Re-run \`./ane bench\` to update performance data.
> Last updated: $(date '+%Y-%m-%d %H:%M:%S')

## System

| | |
|:---|:---|
| Hostname | $_hostname |
| OS | $_os_name $_os_ver ($_os_build) |
| Architecture | $_arch |
| CPU | $_cpu_brand |
| CPU Cores | $_cpu_cores total ($_pcores performance + $_ecores efficiency) |
| RAM | ${_ram_gb} GB |
| Xcode CLI | $_xcode_path |

## Apple Neural Engine

| | |
|:---|:---|
| Chip | ${_ane_chip:-unknown} |
| ANE Architecture | ${_ane_arch:-unknown} |
| ANE Cores | ${_ane_cores:-unknown} |
| API | ${_ane_api:-unknown} |
| Apple Spec | ${_ane_tops:-?} TOPS (INT8, marketing) |
| Thermal | ${_ane_thermal:-unknown} |

## Measured Performance

| | |
|:---|:---|
| Quick Peak | ${_ane_tflops:-not measured} TFLOPS (fp16) |
| Full Peak | ${_peak:-run ./ane bench} TFLOPS |
| Sustained (5s) | ${_sustained:-run ./ane bench} TFLOPS |
| Dispatch Overhead | ${_dispatch:-run ./ane bench} ms/kernel |
| Best Kernel Shape | ${_best_kernel:-run ./ane bench} |
| Efficiency vs Spec | ${_efficiency:-run ./ane bench}% |
| Optimal QoS | ${_optimal_qos:-background} |

## Known Limits

| Constraint | Value |
|:---|:---|
| SRAM | ~32 MB (all Apple Silicon) |
| Compile Budget | ~119 per process |
| IOSurface Buffer Slots | 128 per execution |
| Internal Priority Queues | 8 (p0–p7) |
| Thermal Throttling | Not observed under sustained load |
PROFILE_EOF

    echo "$DEVICE_PROFILE"
}

# Check if device profile exists, create if not
ensure_device_profile() {
    if [ ! -f "$DEVICE_PROFILE" ]; then
        dim "$(t "Creating device profile ..." "Erstelle Geräteprofil ...")"
        local _path
        _path=$(create_device_profile)
        ok "$(t "Device profile: $_path" "Geräteprofil: $_path")"
    fi
}

# ===== Profile Helpers =====
# Load cached profile — all keys become shell variables
load_profile() {
    [ -f "$PROFILE" ] || return 1
    . "$PROFILE" 2>/dev/null
    return 0
}

# Check if profile is fresh (< 7 days old)
profile_fresh() {
    [ -f "$PROFILE" ] || return 1
    local now ts age
    now=$(date +%s)
    ts=$(grep '^timestamp=' "$PROFILE" 2>/dev/null | cut -d= -f2)
    [ -z "$ts" ] && return 1
    age=$(( now - ts ))
    [ "$age" -lt 604800 ]  # 7 days
}

# Check if system has been benchmarked (tuned profile exists)
is_tuned() {
    [ -f "$PROFILE" ] && grep -q '^tuned_ch=' "$PROFILE" 2>/dev/null
}

# Check if benchmark has been run at all
is_benchmarked() {
    [ -f "$PROFILE" ] && grep -q '^peak_tflops=' "$PROFILE" 2>/dev/null
}

# Show "benchmark required" message for locked options
require_benchmark() {
    echo ""
    fail "$(t "Benchmark required first! This optimizes the ANE for your chip." "Benchmark nötig! Damit wird der ANE für deinen Chip optimiert.")"
    info "$(t "Select option 2 (Benchmark) to set up your system." "Wähle Option 2 (Benchmark) um dein System einzurichten.")"
    echo ""
}

# ===== Colors =====
R='\033[0;31m'
G='\033[0;32m'
Y='\033[1;33m'
B='\033[0;34m'
C='\033[0;36m'
W='\033[1;37m'
D='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m'

# ===== Helpers =====
ok()   { echo -e "  ${G}+${NC} $1"; }
fail() { echo -e "  ${R}x${NC} $1"; }
info() { echo -e "  ${B}>${NC} $1"; }
dim()  { echo -e "  ${D}$1${NC}"; }

# ===== System Check =====
check_system() {
    if [ "$(uname -m)" != "arm64" ]; then
        fail "$(t "Apple Silicon required (you have: $(uname -m))" "Apple Silicon erforderlich (du hast: $(uname -m))")"
        exit 1
    fi
    if ! xcode-select -p &>/dev/null; then
        fail "$(t "Xcode Command Line Tools not found" "Xcode Command Line Tools nicht gefunden")"
        info "$(t "Install with: xcode-select --install" "Installiere mit: xcode-select --install")"
        exit 1
    fi
}

# ===== Build =====
ensure_built() {
    local target="$1"
    local binary="$2"
    if [ ! -f "$EXAMPLES/$binary" ]; then
        echo -e "  ${D}$(t "Building $binary ..." "Baue $binary ...")${NC}"
        (cd "$EXAMPLES" && make "$target" 2>/dev/null) || {
            fail "$(t "Build failed. Try: cd examples && make $target" "Build fehlgeschlagen. Versuche: cd examples && make $target")"
            return 1
        }
    fi
}

ensure_all_built() {
    local needed=0
    [ ! -f "$EXAMPLES/demo_train" ] && needed=1
    [ ! -f "$EXAMPLES/bench" ] && needed=1
    [ ! -f "$EXAMPLES/generate" ] && needed=1
    [ ! -f "$EXAMPLES/explore" ] && needed=1

    if [ $needed -eq 1 ]; then
        echo ""
        info "$(t "First run — building all binaries ..." "Erstmaliger Start — baue alle Binaries ...")"
        echo ""
        (cd "$EXAMPLES" && make all 2>&1 | while read -r line; do dim "  $line"; done) || {
            fail "$(t "Build failed" "Build fehlgeschlagen")"
            exit 1
        }
        ok "$(t "All binaries built" "Alle Binaries gebaut")"
        echo ""
    fi
}

# ===== Hardware Info =====
cmd_info() {
    check_system
    ensure_built "demo_train" "demo_train"
    ensure_built "bench_bin" "bench"

    echo ""
    echo -e "  ${BOLD}$(t "Hardware Info" "Hardware-Erkennung")${NC}"
    echo ""

    # Run a quick ANE init to get hardware info
    "$EXAMPLES/demo_train" 2>/dev/null | head -6 | while read -r line; do
        echo -e "  $line"
    done

    # Get thermal + quick peak from bench
    local quick_data
    quick_data=$("$EXAMPLES/bench" --quick 2>/dev/null)
    if [ -n "$quick_data" ]; then
        local _thermal
        _thermal=$(echo "$quick_data" | sed -n 's/.*THERMAL:\(.*\)/\1/p')
        if [ -n "$_thermal" ]; then
            echo -e "  ${D}Thermal:${NC} $_thermal"
        fi
    fi

    echo ""
    echo -e "  ${D}System:${NC}  $(sw_vers -productName) $(sw_vers -productVersion) ($(sw_vers -buildVersion))"
    echo -e "  ${D}Arch:${NC}    $(uname -m)"
    echo -e "  ${D}Xcode:${NC}   $(xcode-select -p)"
    echo ""
}

# ===== Commands =====
cmd_train() {
    check_system
    ensure_built "demo_train" "demo_train"
    echo ""
    "$EXAMPLES/demo_train"
    echo ""
}

cmd_bench() {
    check_system
    ensure_built "bench_bin" "bench"
    echo ""
    echo -e "  ${BOLD}$(t "Step 1: Auto-tuning for your chip ..." "Schritt 1: Auto-Tuning für deinen Chip ...")${NC}"
    echo -e "  ${D}$(t "Finding the optimal kernel shapes (~2 min) ..." "Finde optimale Kernel-Shapes (~2 Min) ...")${NC}"
    echo ""
    "$EXAMPLES/bench" --tune --save-profile="$PROFILE"
    if [ -f "$PROFILE" ]; then
        ok "$(t "System optimized and profile saved" "System optimiert und Profil gespeichert")"
        create_device_profile >/dev/null
        ok "$(t "Device profile: $DEVICE_PROFILE" "Geräteprofil: $DEVICE_PROFILE")"
        echo ""
        ok "$(t "All features unlocked! You can now use all menu options." "Alle Funktionen freigeschaltet! Du kannst jetzt alle Menü-Optionen nutzen.")"
    fi
    echo ""
}

cmd_generate() {
    check_system
    ensure_built "generate_bin" "generate"
    echo ""
    "$EXAMPLES/generate"
    echo ""
}

cmd_explore() {
    check_system
    ensure_built "explore_bin" "explore"
    echo ""
    "$EXAMPLES/explore"
    echo ""
}

cmd_test() {
    check_system
    echo ""
    info "$(t "Running libane tests ..." "libane Tests ...")"
    echo ""
    (cd "$LIBANE" && make test 2>&1)
    echo ""
}

cmd_profile() {
    check_system
    ensure_built "bench_bin" "bench"
    echo ""
    info "$(t "Generating device profile ..." "Erstelle Geräteprofil ...")"
    local _path
    _path=$(create_device_profile)
    ok "$(t "Saved: $_path" "Gespeichert: $_path")"
    echo ""
    cat "$DEVICE_PROFILE"
    echo ""
}

cmd_monitor() {
    check_system
    local TRAINING="$DIR/training"
    if [ ! -f "$TRAINING/test_ane_monitor" ]; then
        echo ""
        info "$(t "Building ANE monitor ..." "Baue ANE Monitor ...")"
        (cd "$TRAINING" && make test_ane_monitor 2>/dev/null) || {
            fail "$(t "Build failed" "Build fehlgeschlagen")"
            return 1
        }
    fi
    echo ""
    "$TRAINING/test_ane_monitor"
    echo ""
}

