# ===== Banner =====
show_banner() {
    echo ""
    echo -e "  ${BOLD}${W} ___    _   __ ______${NC}"
    echo -e "  ${BOLD}${W}/   |  / | / // ____/${NC}"
    echo -e "  ${BOLD}${W}/ /| | /  |/ // __/${NC}     ${D}Apple Neural Engine${NC}"
    echo -e "  ${BOLD}${W}/ ___ |/ /|  // /___${NC}    ${D}Training Platform${NC}"
    echo -e "  ${BOLD}${W}/_/  |_/_/ |_//_____/${NC}   ${D}1 Compile · ∞ Steps${NC}"
    echo ""
}

# ===== Interactive Menu =====
cmd_menu() {
    check_system

    show_banner
    ensure_all_built

    # Hardware + peak detection: use cached profile if fresh, else --quick
    if profile_fresh && load_profile; then
        # Cached profile — instant, no ANE access needed
        ok "Hardware: ${W}${arch}${NC} (${chip}), ${cores} cores"
        if [ -n "$apple_tops" ] && [ "$apple_tops" != "0" ]; then
            local _pct
            _pct=$(awk "BEGIN { printf \"%.0f\", $peak_tflops / $apple_tops * 100 }")
            ok "ANE Peak: ${W}${peak_tflops} TFLOPS${NC} (${apple_tops} TOPS Apple spec, ${_pct}%)"
        else
            ok "ANE Peak: ${W}${peak_tflops} TFLOPS${NC}"
        fi
        ok "API: v${api_version}(${api_classes})"
        local _profile_date
        _profile_date=$(date -r "$timestamp" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "?")
        dim "Profile: $_profile_date | ./ane bench $(t "to refresh" "zum Aktualisieren")"
    else
        # No profile or expired — run quick peak (~1s)
        local quick_data
        quick_data=$("$EXAMPLES/bench" --quick 2>/dev/null)
        if [ -n "$quick_data" ] && [ "$quick_data" != "ERROR" ]; then
            local _tflops _tops _chip _arch _cores _api
            _tflops=$(echo "$quick_data" | sed -n 's/.*TFLOPS:\([^|]*\).*/\1/p')
            _tops=$(echo "$quick_data" | sed -n 's/.*TOPS:\([^|]*\).*/\1/p')
            _chip=$(echo "$quick_data" | sed -n 's/.*CHIP:\([^|]*\).*/\1/p')
            _arch=$(echo "$quick_data" | sed -n 's/.*ARCH:\([^|]*\).*/\1/p')
            _cores=$(echo "$quick_data" | sed -n 's/.*CORES:\([^|]*\).*/\1/p')
            _api=$(echo "$quick_data" | sed -n 's/.*API:\([^|]*\).*/\1/p')

            ok "Hardware: ${W}${_arch}${NC} (${_chip}), ${_cores} cores"
            if [ -n "$_tops" ] && [ "$_tops" != "0" ]; then
                local _pct
                _pct=$(awk "BEGIN { printf \"%.0f\", $_tflops / $_tops * 100 }")
                ok "ANE Peak: ${W}${_tflops} TFLOPS${NC} (~quick, ${_tops} TOPS Apple spec, ${_pct}%)"
            else
                ok "ANE Peak: ${W}${_tflops} TFLOPS${NC} (~quick)"
            fi
            ok "API: ${_api}"
            info "$(t "Run ./ane bench for full profile + cached results" "Starte ./ane bench für volles Profil + Cache")"
        else
            # Fallback to basic hardware detect
            local hw_line
            hw_line=$("$EXAMPLES/demo_train" 2>/dev/null | grep "Hardware:" | head -1)
            if [ -n "$hw_line" ]; then echo -e "  ${G}+${NC} $hw_line"; fi
            local api_line
            api_line=$("$EXAMPLES/demo_train" 2>/dev/null | grep "API:" | head -1)
            if [ -n "$api_line" ]; then echo -e "  ${G}+${NC} $api_line"; fi
        fi
    fi

    while true; do
        echo ""
        echo -e "  ${D}─────────────────────────────────────${NC}"
        echo ""
        echo -e "    ${W}1${NC}  Training Demo       ${D}$(t "Train Y=2X, 1 compile, 60 steps" "Train Y=2X, 1 Compile, 60 Steps")${NC}"
        echo -e "    ${W}2${NC}  Benchmark            ${D}$(t "Measure your ANE TFLOPS" "Messe deine ANE TFLOPS")${NC}"
        echo -e "    ${W}3${NC}  Text Generation      ${D}$(t "Shakespeare on the ANE" "Shakespeare auf dem ANE")${NC}"
        echo -e "    ${W}4${NC}  ANE Explorer          ${D}$(t "Explore 35 private classes" "35 private Klassen erkunden")${NC}"
        echo -e "    ${W}5${NC}  $(t "Hardware Info" "Hardware Info")         ${D}$(t "Chip, cores, API status" "Chip, Cores, API-Status")${NC}"
        echo -e "    ${W}6${NC}  $(t "libane Test Suite" "libane Tests")          ${D}$(t "Run the test suite" "Test-Suite laufen lassen")${NC}"
        echo ""
        echo -e "    ${W}?${NC}  $(t "What is this?" "Was ist das?")           ${D}$(t "Why ANE training? Key differentiators." "Warum ANE-Training? USP.")${NC}"
        echo -e "    ${W}d${NC}  $(t "Documentation" "Dokumentation")         ${D}$(t "Open README in browser" "README im Browser öffnen")${NC}"
        echo -e "    ${W}q${NC}  $(t "Quit" "Beenden")"
        echo ""
        echo -ne "  ${BOLD}$(t "Select:" "Auswahl:") ${NC}"

        read -r choice

        case "$choice" in
            1) cmd_train ;;
            2) cmd_bench ;;
            3) cmd_generate ;;
            4) cmd_explore ;;
            5) cmd_info ;;
            6) cmd_test ;;
            '?'|about) cmd_about ;;
            d|D)
                if [ -f "$DIR/README.md" ]; then
                    if command -v open &>/dev/null; then
                        open "https://github.com/slavko-at-klincov-it/ANE-Training"
                    else
                        info "README: $DIR/README.md"
                    fi
                fi
                ;;
            q|Q|"") echo ""; break ;;
            *) fail "$(t "Unknown selection: $choice" "Unbekannte Auswahl: $choice")" ;;
        esac
    done
}

# ===== Main =====
# Strip --lang flags from positional args
ARGS=()
for arg in "$@"; do
    case "$arg" in
        --lang=*) ;;  # already handled above
        *) ARGS+=("$arg") ;;
    esac
done

case "${ARGS[0]:-}" in
    about|what|"?") cmd_about ;;
    train)    cmd_train ;;
    bench)    cmd_bench ;;
    generate) cmd_generate ;;
    explore)  cmd_explore ;;
    info)     cmd_info ;;
    test)     cmd_test ;;
    help|-h|--help) cmd_help ;;
    "")       cmd_menu ;;
    *)
        fail "$(t "Unknown command: ${ARGS[0]}" "Unbekannter Befehl: ${ARGS[0]}")"
        cmd_help
        exit 1
        ;;
esac
